      "parameters": {
        "jsCode": "const FALLBACK = 'Sorry \u2014 I could not generate a reply right now. Please try again shortly, or book a discovery call at http://178.104.254.165/#discovery-call';\n\nreturn $input.all().map(item => {\n  const content = item.json.choices?.[0]?.message?.content ?? '';\n  const text = (typeof content === 'string' ? content : JSON.stringify(content)).trim();\n\n  return {\n    json: {\n      output: text || FALLBACK,\n    },\n  };\n});"
      },
