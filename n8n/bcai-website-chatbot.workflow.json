      "parameters": {
        "jsCode": "const CACHE_TTL_MS = 10 * 60 * 1000;\nconst trigger = $input.first().json;\nconst staticData = $getWorkflowStaticData('global');\nconst cachedAt = staticData.knowledgeCachedAt || 0;\nconst knowledge = staticData.knowledge || '';\nconst isFresh = Boolean(knowledge) && (Date.now() - cachedAt < CACHE_TTL_MS);\n\nreturn [{\n  json: {\n    chatInput: trigger.chatInput,\n    sessionId: trigger.sessionId,\n    knowledge: isFresh ? knowledge : '',\n    fromCache: isFresh,\n  },\n}];"
      },
