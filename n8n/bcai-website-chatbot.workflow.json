    {
      "parameters": {
        "jsCode": "const parts = [];\n\nfor (const item of $input.all()) {\n  const name = item.json.name || item.json.fileName || 'document';\n  let text = '';\n  const binKey = item.binary ? Object.keys(item.binary)[0] : null;\n  if (binKey && item.binary[binKey]?.data) {\n    text = Buffer.from(item.binary[binKey].data, 'base64').toString('utf8');\n  }\n  if (text.trim()) {\n    parts.push(`### ${name}\\n${text.trim()}`);\n  }\n}\n\nconst knowledge = parts.join('\\n\\n---\\n\\n') || '(No knowledge files found in Drive folder.)';\n\nconst staticData = $getWorkflowStaticData('global');\nstaticData.knowledge = knowledge;\nstaticData.knowledgeCachedAt = Date.now();\n\nlet chatInput = '';\nlet sessionId = '';\nlet warmOnly = false;\n\ntry {\n  const meta = $('Check knowledge cache').first().json;\n  chatInput = meta.chatInput || '';\n  sessionId = meta.sessionId || '';\n} catch (error) {\n  warmOnly = true;\n}\n\nreturn [{\n  json: {\n    chatInput,\n    sessionId,\n    knowledge,\n    fromCache: false,\n    warmOnly,\n  },\n}];"
      },
