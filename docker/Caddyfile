(common_n8n) {
	handle /webhook/* {
		reverse_proxy n8n:5678
	}
	handle /rest/oauth2-credential/* {
		reverse_proxy n8n:5678
	}
}

(ai_ivr) {
	handle /webhooks/* {
		reverse_proxy ai_ivr:8000
	}
	handle /api/* {
		reverse_proxy ai_ivr:8000
	}
	handle /admin/* {
		reverse_proxy ai_ivr:8000
	}
	handle /static/* {
		reverse_proxy ai_ivr:8000
	}
	handle /dev/* {
		reverse_proxy ai_ivr:8000
	}
	handle /health {
		reverse_proxy ai_ivr:8000
	}
	handle /assessment {
		rewrite * /
		reverse_proxy ai_ivr:8000
	}
}

# HTTP: keep webhook POST endpoints reachable without TLS redirect (Retell/n8n).
:80 {
	import common_n8n
	handle /webhooks/* {
		reverse_proxy ai_ivr:8000
	}
	handle {
		redir https://{host}{uri} permanent
	}
}

# Shared HTTPS access log (JSON). Count visitors later with:
#   jq -r 'select(.request.host=="www.bespoke-ai.ie") | .request.remote_ip' docker/logs/access.log | sort -u | wc -l
(access_log) {
	log {
		output file /var/log/caddy/access.log {
			roll_size 50mb
			roll_keep 14
			roll_keep_for 336h
		}
		format json
	}
}

# HTTPS: Let's Encrypt via Caddy (automatic once DNS is live).
bespoke-ai.ie, www.bespoke-ai.ie {
	import access_log
	tls karlnolan@bespoke-ai.ie
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"
	import common_n8n
	import ai_ivr
	handle {
		reverse_proxy site:8080
	}
}

# n8n editor UI (Google OAuth needs HTTPS on a domain, not http://IP:5678).
# Webhooks stay on www.bespoke-ai.ie via common_n8n above.
n8n.bespoke-ai.ie {
	import access_log
	tls karlnolan@bespoke-ai.ie
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"
	reverse_proxy n8n:5678
}
